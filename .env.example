# Local content admin login (do not commit real values)
CONTENT_ADMIN_PASSWORD=change-this-local-password
CONTENT_ADMIN_SESSION_SECRET=replace-with-a-random-string-at-least-32-characters

# Local prototype storage. The production adapter will use PostgreSQL later.
CONTENT_ADMIN_STORAGE=local

# Vercel/Neon: set CONTENT_ADMIN_STORAGE=postgres and provide either variable.
# DATABASE_URL=postgresql://...
# POSTGRES_URL=postgresql://...

# Existing public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Existing LINE login integration (required only if LINE login is enabled)
# LINE_CHANNEL_ID=
# LINE_CHANNEL_SECRET=
